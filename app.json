{
  "expo": {
    "name": "eKazi Vendor",
    "slug": "eVendor",
    "version": "1.0.0.4",
    "runtimeVersion": "1.0.0.4",
    "orientation": "portrait",
    "icon": "./assets/Image_eKazi.png",
    "scheme": "ekazi-vendor",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ricardo96.ekazi.vendor",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to prefill your address during registration."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ricardo96.ekazi.vendor",
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-location"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3d6062a8-8e0e-4f92-baf8-3e8658895ced"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/e139a047-c2ae-4929-8e4c-0ae7175d1f65"
    }
  }
}
